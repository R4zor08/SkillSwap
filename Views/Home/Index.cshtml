@model SkillSwap.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col-md-12">
        <h1>Welcome, @Model.Student.Name!</h1>
        <p class="lead">Manage your skills and trade requests</p>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h3>My Talents</h3>
            </div>
            <div class="card-body">
                @if (Model.Talents.Any())
                {
                    <ul class="list-group">
                        @foreach (var talent in Model.Talents)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@talent.TalentName</strong><br />
                                    <small class="text-muted">@talent.Description</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@talent.ProficiencyLevel</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No talents added yet.</p>
                }
                <div class="mt-3">
                    <a asp-controller="Talents" asp-action="Create" class="btn btn-primary">Add New Talent</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h3>Incoming Requests</h3>
            </div>
            <div class="card-body">
                @if (Model.IncomingRequests.Any())
                {
                    <ul class="list-group">
                        @foreach (var request in Model.IncomingRequests)
                        {
                            <li class="list-group-item">
                                <div>
                                    <strong>@request.RequestedTalent?.TalentName</strong><br />
                                    <small class="text-muted">From: @request.RequestingStudent?.Name</small><br />
                                    <small class="text-muted">Offered: @request.OfferedTalent?.TalentName</small>
                                </div>
                                <div class="mt-2">
                                    <a asp-controller="Trades" asp-action="Accept" asp-route-id="@request.TradeId" class="btn btn-success btn-sm">Accept</a>
                                    <a asp-controller="Trades" asp-action="Reject" asp-route-id="@request.TradeId" class="btn btn-danger btn-sm">Reject</a>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No incoming requests.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h3>Outgoing Requests</h3>
            </div>
            <div class="card-body">
                @if (Model.OutgoingRequests.Any())
                {
                    <ul class="list-group">
                        @foreach (var request in Model.OutgoingRequests)
                        {
                            <li class="list-group-item">
                                <div>
                                    <strong>@request.RequestedTalent?.TalentName</strong><br />
                                    <small class="text-muted">To: @request.TargetStudent?.Name</small><br />
                                    <small class="text-muted">Status: @request.Status</small>
                                </div>
                                <div class="mt-2">
                                    <span class="badge bg-@(request.Status == TradeStatus.Pending ? "warning" : request.Status == TradeStatus.Accepted ? "success" : "danger")">
                                        @request.Status
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No outgoing requests.</p>
                }
                <div class="mt-3">
                    <a asp-controller="Trades" asp-action="Create" class="btn btn-warning">New Trade Request</a>
                </div>
            </div>
        </div>
    </div>
</div>
