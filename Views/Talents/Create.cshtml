@model Talent

@{
    ViewData["Title"] = "Create Talent";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card">
                <div class="card-header border-0 py-4" style="background: rgba(0, 255, 136, 0.1);">
                    <h3 class="mb-0" style="color: var(--neon-green);">
                        <i class="bi bi-plus-circle me-2"></i>UPLOAD SKILL
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4">
                            <label for="studentId" class="form-label" style="color: var(--neon-green);">
                                <i class="bi bi-person-badge me-1"></i>IDENTITY
                            </label>
                            <select class="form-select" id="studentId" name="studentId" required style="background: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.3); color: #fff;">
                                <option value="">-- Select Node --</option>
                                @foreach (var student in ViewBag.Students)
                                {
                                    <option value="@student.StudentId">@student.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label for="name" class="form-label" style="color: var(--neon-green);">
                                <i class="bi bi-star me-1"></i>SKILL NAME
                            </label>
                            <input type="text" class="form-control" id="name" name="name" required 
                                   placeholder="e.g., Guitar, Python Programming, Photography" maxlength="100"
                                   style="background: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.3); color: #fff;">
                        </div>

                        <div class="mb-4">
                            <label for="description" class="form-label" style="color: var(--neon-green);">
                                <i class="bi bi-file-text me-1"></i>DESCRIPTION
                            </label>
                            <textarea class="form-control" id="description" name="description" rows="3" 
                                      placeholder="Describe your skill and experience level"
                                      style="background: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.3); color: #fff;"></textarea>
                        </div>

                        <div class="mb-4">
                            <label for="proficiencyLevel" class="form-label" style="color: var(--neon-green);">
                                <i class="bi bi-bar-chart me-1"></i>PROFICIENCY LEVEL (1-10)
                            </label>
                            <input type="number" class="form-control" id="proficiencyLevel" name="proficiencyLevel" 
                                   min="1" max="10" value="5" required
                                   style="background: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.3); color: #fff;">
                            <div class="form-text text-secondary">Rate your skill level from 1 (beginner) to 10 (expert)</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn" style="background: rgba(160, 160, 192, 0.2); color: var(--text-secondary); border: 1px solid rgba(160, 160, 192, 0.3);">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn" style="background: var(--neon-green); color: #000;">
                                <i class="bi bi-check-circle me-1"></i>Upload
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .glass-card {
            background: rgba(10, 10, 20, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 255, 136, 0.2);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .form-control, .form-select {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus, .form-select:focus {
            background: rgba(0, 255, 136, 0.1);
            border-color: var(--neon-green);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.3);
            color: #fff;
        }
        
        .form-control::placeholder {
            color: #606080;
        }
        
        .form-select option {
            background: #0a0a14;
            color: #fff;
        }
    </style>
}
