@model Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card" style="border-color: rgba(255, 0, 85, 0.3);">
                <div class="card-header border-0 py-4" style="background: rgba(255, 0, 85, 0.1);">
                    <h3 class="mb-0" style="color: var(--danger-color);">
                        <i class="bi bi-exclamation-triangle me-2"></i>TERMINATE NODE
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="alert" style="background: rgba(255, 0, 85, 0.1); border: 1px solid rgba(255, 0, 85, 0.3); border-radius: 12px;">
                        <strong style="color: var(--danger-color);">WARNING!</strong> <span class="text-secondary">This action cannot be undone. Are you sure you want to delete this node?</span>
                    </div>

                    <div class="mb-4">
                        <h5 style="color: var(--danger-color);">Node Details:</h5>
                        <dl class="row">
                            <dt class="col-sm-4 text-secondary">Identity:</dt>
                            <dd class="col-sm-8 text-white">@Model.Name</dd>

                            <dt class="col-sm-4 text-secondary">Comm Channel:</dt>
                            <dd class="col-sm-8" style="color: var(--neon-green);">@Model.Email</dd>

                            <dt class="col-sm-4 text-secondary">Node ID:</dt>
                            <dd class="col-sm-8"><code style="color: var(--neon-cyan);">@Model.StudentId</code></dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.StudentId" />
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn" style="background: rgba(160, 160, 192, 0.2); color: var(--text-secondary); border: 1px solid rgba(160, 160, 192, 0.3);">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn" style="background: var(--danger-color); color: #fff;">
                                <i class="bi bi-trash me-1"></i>Terminate
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .glass-card {
            background: rgba(10, 10, 20, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 0, 85, 0.3);
            border-radius: 16px;
            overflow: hidden;
        }
    </style>
}
