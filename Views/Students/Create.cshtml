@model Student

@{
    ViewData["Title"] = "Create Student";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card">
                <div class="card-header border-0 py-4" style="background: rgba(0, 245, 255, 0.1);">
                    <h3 class="mb-0" style="color: var(--neon-cyan);">
                        <i class="bi bi-person-plus me-2"></i>INITIALIZE NODE
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4">
                            <label for="name" class="form-label" style="color: var(--neon-cyan);">
                                <i class="bi bi-person-badge me-1"></i>IDENTITY
                            </label>
                            <input type="text" class="form-control" id="name" name="name" required 
                                   placeholder="Enter full name" maxlength="100"
                                   style="background: rgba(0, 245, 255, 0.05); border: 1px solid rgba(0, 245, 255, 0.3); color: #fff;">
                            <div class="form-text text-secondary">Node's full identity</div>
                        </div>

                        <div class="mb-4">
                            <label for="email" class="form-label" style="color: var(--neon-cyan);">
                                <i class="bi bi-envelope me-1"></i>COMM CHANNEL
                            </label>
                            <input type="email" class="form-control" id="email" name="email" required 
                                   placeholder="Enter email address" maxlength="100"
                                   style="background: rgba(0, 245, 255, 0.05); border: 1px solid rgba(0, 245, 255, 0.3); color: #fff;">
                            <div class="form-text text-secondary">Valid communication address</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn" style="background: rgba(160, 160, 192, 0.2); color: var(--text-secondary); border: 1px solid rgba(160, 160, 192, 0.3);">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Initialize
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .glass-card {
            background: rgba(10, 10, 20, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 245, 255, 0.2);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .form-control {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus {
            background: rgba(0, 245, 255, 0.1);
            border-color: var(--neon-cyan);
            box-shadow: 0 0 20px rgba(0, 245, 255, 0.3);
            color: #fff;
        }
        
        .form-control::placeholder {
            color: #606080;
        }
    </style>
}
