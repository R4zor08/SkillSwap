@model SkillSwap.Web.ViewModels.TradeIndexViewModel

@{
    ViewData["Title"] = "Trade Requests";
}

<div class="container-fluid py-4">
    <!-- Futuristic Page Header -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold mb-2 neon-text" style="color: var(--neon-orange);">
                <i class="bi bi-arrow-left-right me-3"></i>EXCHANGE PROTOCOL
            </h1>
            <p class="text-secondary fs-5">
                <i class="bi bi-diagram-3 me-2"></i>Skill transfer negotiations and transactions
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-controller="Trades" asp-action="Create" class="btn btn-lg" style="background: var(--neon-orange); color: #000;">
                <i class="bi bi-plus-circle me-2"></i>INITIATE TRADE
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 col-6 mb-3 mb-md-0">
            <div class="glass-card animate-glow h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-inbox mb-2" style="font-size: 2rem; color: var(--neon-cyan);"></i>
                    <h6 class="text-uppercase mb-2" style="color: var(--neon-cyan); letter-spacing: 2px; font-size: 0.75rem;">Incoming</h6>
                    <h3 class="mb-0 fw-bold neon-text" style="color: var(--neon-cyan);">@Model.IncomingRequests.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3 mb-md-0">
            <div class="glass-card animate-glow h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-box-arrow-up mb-2" style="font-size: 2rem; color: var(--neon-orange);"></i>
                    <h6 class="text-uppercase mb-2" style="color: var(--neon-orange); letter-spacing: 2px; font-size: 0.75rem;">Outgoing</h6>
                    <h3 class="mb-0 fw-bold neon-text" style="color: var(--neon-orange);">@Model.OutgoingRequests.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="glass-card animate-glow h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-check-circle mb-2" style="font-size: 2rem; color: var(--neon-green);"></i>
                    <h6 class="text-uppercase mb-2" style="color: var(--neon-green); letter-spacing: 2px; font-size: 0.75rem;">Accepted</h6>
                    <h3 class="mb-0 fw-bold neon-text" style="color: var(--neon-green);">@Model.IncomingRequests.Count(r => r.Status == TradeStatus.Accepted)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="glass-card animate-glow h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-clock mb-2" style="font-size: 2rem; color: var(--neon-magenta);"></i>
                    <h6 class="text-uppercase mb-2" style="color: var(--neon-magenta); letter-spacing: 2px; font-size: 0.75rem;">Pending</h6>
                    <h3 class="mb-0 fw-bold neon-text" style="color: var(--neon-magenta);">@Model.IncomingRequests.Count(r => r.Status == TradeStatus.Pending)</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Trade Requests -->
    <div class="row g-4">
        <!-- Incoming Requests -->
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="card-header border-0 py-4 d-flex justify-content-between align-items-center" style="background: rgba(0, 245, 255, 0.1);">
                    <h5 class="mb-0" style="color: var(--neon-cyan);">
                        <i class="bi bi-inbox me-2"></i>INCOMING TRANSFERS
                    </h5>
                    <span class="badge" style="background: var(--neon-cyan); color: #000;">@Model.IncomingRequests.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.IncomingRequests.Any())
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="px-4 py-4" style="color: var(--neon-cyan);">SOURCE</th>
                                        <th class="py-4" style="color: var(--neon-cyan);">EXCHANGE</th>
                                        <th class="py-4 text-center" style="color: var(--neon-cyan);">STATUS</th>
                                        <th class="text-center py-4" style="color: var(--neon-cyan);">OPS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model.IncomingRequests)
                                    {
                                        var (bgColor, textColor) = request.Status switch
                                        {
                                            TradeStatus.Pending => ("rgba(255, 0, 255, 0.2)", "var(--neon-magenta)"),
                                            TradeStatus.Accepted => ("rgba(0, 255, 136, 0.2)", "var(--neon-green)"),
                                            TradeStatus.Rejected => ("rgba(255, 0, 85, 0.2)", "var(--danger-color)"),
                                            TradeStatus.Completed => ("rgba(0, 245, 255, 0.2)", "var(--neon-cyan)"),
                                            _ => ("rgba(160, 160, 192, 0.2)", "var(--text-secondary)")
                                        };
                                        <tr class="align-middle">
                                            <td class="px-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle p-2 me-2" style="background: rgba(0, 245, 255, 0.1);">
                                                        <i class="bi bi-person" style="color: var(--neon-cyan);"></i>
                                                    </div>
                                                    <span class="fw-semibold text-white">@request.RequestingStudent?.Name</span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small">
                                                    <div><span class="text-secondary">Requests:</span> <span style="color: var(--neon-green);">@request.RequestedTalent?.TalentName</span></div>
                                                    <div><span class="text-secondary">Offers:</span> <span style="color: var(--neon-orange);">@request.OfferedTalent?.TalentName</span></div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge" style="background: @bgColor; color: @textColor;">
                                                    @request.Status
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                @if (request.Status == TradeStatus.Pending)
                                                {
                                                    <div class="btn-group btn-group-sm">
                                                        <form asp-action="Accept" asp-route-id="@request.TradeId" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm" style="background: var(--neon-green); color: #000;" title="Accept">
                                                                <i class="bi bi-check-lg"></i>
                                                            </button>
                                                        </form>
                                                        <form asp-action="Reject" asp-route-id="@request.TradeId" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm" style="background: transparent; border: 1px solid var(--danger-color); color: var(--danger-color);" title="Reject">
                                                                <i class="bi bi-x-lg"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                                else if (request.Status == TradeStatus.Accepted)
                                                {
                                                    <form asp-action="Complete" asp-route-id="@request.TradeId" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm" style="background: var(--neon-cyan); color: #000;">
                                                            <i class="bi bi-check-all me-1"></i>Complete
                                                        </button>
                                                    </form>
                                                }
                                                <a asp-action="Details" asp-route-id="@request.TradeId" class="btn btn-sm ms-1" style="background: rgba(0, 245, 255, 0.1); color: var(--neon-cyan); border: 1px solid var(--neon-cyan);" title="View">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox d-block mb-3" style="font-size: 3rem; color: var(--neon-cyan); opacity: 0.3;"></i>
                            <p class="fs-5 mb-3 text-secondary">No incoming transfers detected</p>
                            <p class="small text-secondary">When someone requests your skills,<br>they'll appear in this sector.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Outgoing Requests -->
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="card-header border-0 py-4 d-flex justify-content-between align-items-center" style="background: rgba(255, 136, 0, 0.1);">
                    <h5 class="mb-0" style="color: var(--neon-orange);">
                        <i class="bi bi-box-arrow-up me-2"></i>OUTGOING TRANSFERS
                    </h5>
                    <span class="badge" style="background: var(--neon-orange); color: #000;">@Model.OutgoingRequests.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.OutgoingRequests.Any())
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="px-4 py-4" style="color: var(--neon-orange);">TARGET</th>
                                        <th class="py-4" style="color: var(--neon-orange);">EXCHANGE</th>
                                        <th class="py-4 text-center" style="color: var(--neon-orange);">STATUS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model.OutgoingRequests)
                                    {
                                        var (bgColor, textColor) = request.Status switch
                                        {
                                            TradeStatus.Pending => ("rgba(255, 0, 255, 0.2)", "var(--neon-magenta)"),
                                            TradeStatus.Accepted => ("rgba(0, 255, 136, 0.2)", "var(--neon-green)"),
                                            TradeStatus.Rejected => ("rgba(255, 0, 85, 0.2)", "var(--danger-color)"),
                                            TradeStatus.Completed => ("rgba(0, 245, 255, 0.2)", "var(--neon-cyan)"),
                                            _ => ("rgba(160, 160, 192, 0.2)", "var(--text-secondary)")
                                        };
                                        <tr class="align-middle">
                                            <td class="px-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle p-2 me-2" style="background: rgba(255, 136, 0, 0.1);">
                                                        <i class="bi bi-person" style="color: var(--neon-orange);"></i>
                                                    </div>
                                                    <span class="fw-semibold text-white">@request.TargetStudent?.Name</span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small">
                                                    <div><span class="text-secondary">You want:</span> <span style="color: var(--neon-green);">@request.RequestedTalent?.TalentName</span></div>
                                                    <div><span class="text-secondary">You offer:</span> <span style="color: var(--neon-orange);">@request.OfferedTalent?.TalentName</span></div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge" style="background: @bgColor; color: @textColor;">
                                                    @request.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-box-arrow-up d-block mb-3" style="font-size: 3rem; color: var(--neon-orange); opacity: 0.3;"></i>
                            <p class="fs-5 mb-3 text-secondary">No outgoing transfers initiated</p>
                            <a asp-controller="Trades" asp-action="Create" class="btn" style="background: var(--neon-orange); color: #000;">
                                <i class="bi bi-plus-circle me-2"></i>INITIATE TRANSFER
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .glass-card {
            background: rgba(10, 10, 20, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 245, 255, 0.2);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .glass-card:hover {
            border-color: rgba(0, 245, 255, 0.4);
            box-shadow: 0 10px 40px rgba(0, 245, 255, 0.2);
        }
        
        .table {
            background: transparent;
        }
        
        .table thead th {
            background: rgba(0, 245, 255, 0.05);
            border-bottom: 2px solid rgba(0, 245, 255, 0.3);
            font-family: 'Orbitron', sans-serif;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-size: 0.85rem;
        }
        
        .table tbody tr {
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(0, 245, 255, 0.1);
        }
        
        .table tbody tr:hover {
            background: rgba(0, 245, 255, 0.05);
        }
        
        .table td {
            border-top: none;
            color: var(--text-primary);
        }
        
        .animate-glow {
            animation: cardGlow 3s ease-in-out infinite;
        }
        
        @@keyframes cardGlow {
            0%, 100% { box-shadow: 0 0 20px rgba(0, 245, 255, 0.1); }
            50% { box-shadow: 0 0 40px rgba(0, 245, 255, 0.2); }
        }
    </style>
}
