@model SkillSwap.Web.ViewModels.TradeCreateViewModel
@{
    ViewData["Title"] = "Create Trade Request";
    var availableTalents = Model?.AvailableTalents ?? new List<TradeTalentPickOption>();
    var myTalents = Model?.MyTalents ?? new List<TradeTalentPickOption>();
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card">
                <div class="card-header border-0 py-4" style="background: rgba(255, 136, 0, 0.1);">
                    <h3 class="mb-0" style="color: var(--neon-orange);">
                        <i class="bi bi-plus-circle me-2"></i>INITIATE TRADE
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="Trades" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label for="requestedTalentId" class="form-label" style="color: var(--neon-orange);">
                                <i class="bi bi-download me-1"></i>SKILL YOU WANT TO ACQUIRE
                            </label>
                            <select class="form-select" id="requestedTalentId" name="requestedTalentId" required style="background: rgba(255, 136, 0, 0.05); border: 1px solid rgba(255, 136, 0, 0.3); color: #fff;">
                                <option value="">-- Select a skill --</option>
                                @foreach (TradeTalentPickOption talent in availableTalents)
                                {
                                    <option value="@talent.TalentId">
                                        @talent.TalentName (by @(talent.OwnerName ?? "Unknown")) - Level @talent.ProficiencyLevel
                                    </option>
                                }
                            </select>
                            <div class="form-text text-secondary">Select a skill you want to learn from other nodes</div>
                            @if (availableTalents.Count == 0)
                            {
                                <p class="small text-warning mt-2 mb-0">No other students have listed skills yet. Add another account or seed talents so this list is not empty.</p>
                            }
                        </div>

                        <div class="mb-4">
                            <label for="offeredTalentId" class="form-label" style="color: var(--neon-orange);">
                                <i class="bi bi-upload me-1"></i>SKILL YOU CAN OFFER
                            </label>
                            <select class="form-select" id="offeredTalentId" name="offeredTalentId" required style="background: rgba(255, 136, 0, 0.05); border: 1px solid rgba(255, 136, 0, 0.3); color: #fff;">
                                <option value="">-- Select your skill --</option>
                                @foreach (TradeTalentPickOption talent in myTalents)
                                {
                                    <option value="@talent.TalentId">
                                        @talent.TalentName - Level @talent.ProficiencyLevel
                                    </option>
                                }
                            </select>
                            <div class="form-text text-secondary">Select a skill you can teach in exchange</div>
                            @if (myTalents.Count == 0)
                            {
                                <p class="small text-warning mt-2 mb-0">You have no skills listed. Go to <a asp-controller="Talents" asp-action="Index" class="link-warning">My Talents</a> and add one before you can offer a trade.</p>
                            }
                        </div>

                        <div class="mb-4">
                            <label for="message" class="form-label" style="color: var(--neon-orange);">
                                <i class="bi bi-chat-dots me-1"></i>MESSAGE (Optional)
                            </label>
                            <textarea class="form-control" id="message" name="message" rows="3"
                                      placeholder="Introduce yourself and explain why you want this exchange..."
                                      style="background: rgba(255, 136, 0, 0.05); border: 1px solid rgba(255, 136, 0, 0.3); color: #fff;"></textarea>
                            <div class="form-text text-secondary">A personal message to the other node</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-controller="Trades" asp-action="Index" class="btn" style="background: rgba(160, 160, 192, 0.2); color: var(--text-secondary); border: 1px solid rgba(160, 160, 192, 0.3);">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn" style="background: var(--neon-orange); color: #000;">
                                <i class="bi bi-send me-1"></i>Transmit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .glass-card {
            background: rgba(10, 10, 20, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 136, 0, 0.2);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .form-control, .form-select {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus, .form-select:focus {
            background: rgba(255, 136, 0, 0.1);
            border-color: var(--neon-orange);
            box-shadow: 0 0 20px rgba(255, 136, 0, 0.3);
            color: #fff;
        }
        
        .form-control::placeholder {
            color: #606080;
        }
        
        .form-select option {
            background: #0a0a14;
            color: #fff;
        }
    </style>
}
