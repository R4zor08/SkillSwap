@model SkillSwap.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login - SkillSwap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-cyan: #00f5ff;
            --neon-magenta: #ff00ff;
            --neon-green: #00ff88;
            --neon-purple: #bf00ff;
        }
        
        * { box-sizing: border-box; }
        
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 50%, #0a0a0f 100%);
            font-family: 'Rajdhani', sans-serif;
            overflow: hidden;
        }
        
        /* Animated background grid */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 245, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 245, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            animation: gridMove 20s linear infinite;
            z-index: 0;
        }
        
        @@keyframes gridMove {
            0% { transform: perspective(500px) rotateX(60deg) translateY(0); }
            100% { transform: perspective(500px) rotateX(60deg) translateY(40px); }
        }
        
        /* Floating particles */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 1;
            pointer-events: none;
        }
        
        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--neon-cyan);
            border-radius: 50%;
            animation: float 15s infinite ease-in-out;
            box-shadow: 0 0 10px var(--neon-cyan);
        }
        
        @@keyframes float {
            0%, 100% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
        }
        
        .login-container {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .login-card {
            background: rgba(10, 10, 20, 0.8);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(0, 245, 255, 0.3);
            border-radius: 24px;
            padding: 3rem;
            max-width: 450px;
            width: 100%;
            box-shadow: 
                0 0 60px rgba(0, 245, 255, 0.2),
                inset 0 0 60px rgba(0, 245, 255, 0.05);
            animation: cardGlow 3s ease-in-out infinite;
            position: relative;
            overflow: hidden;
        }
        
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.1), transparent);
            animation: scan 3s linear infinite;
        }
        
        @@keyframes scan {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        @@keyframes cardGlow {
            0%, 100% { box-shadow: 0 0 60px rgba(0, 245, 255, 0.2), inset 0 0 60px rgba(0, 245, 255, 0.05); }
            50% { box-shadow: 0 0 80px rgba(0, 245, 255, 0.3), inset 0 0 80px rgba(0, 245, 255, 0.08); }
        }
        
        .logo {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .logo h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--neon-cyan) 0%, var(--neon-magenta) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 4px;
            margin: 0;
            text-shadow: 0 0 30px rgba(0, 245, 255, 0.5);
            animation: logoGlow 2s ease-in-out infinite;
        }
        
        @@keyframes logoGlow {
            0%, 100% { filter: brightness(1); }
            50% { filter: brightness(1.2); }
        }
        
        .logo p {
            color: #a0a0c0;
            font-size: 1rem;
            margin-top: 0.5rem;
            letter-spacing: 2px;
        }
        
        .form-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            color: var(--neon-cyan);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }
        
        .form-control {
            background: rgba(0, 245, 255, 0.05);
            border: 1px solid rgba(0, 245, 255, 0.3);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            color: #fff;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus {
            background: rgba(0, 245, 255, 0.1);
            border-color: var(--neon-cyan);
            box-shadow: 0 0 30px rgba(0, 245, 255, 0.3);
            color: #fff;
        }
        
        .form-control::placeholder {
            color: #606080;
        }
        
        .input-group-text {
            background: rgba(0, 245, 255, 0.1);
            border: 1px solid rgba(0, 245, 255, 0.3);
            border-right: none;
            border-radius: 12px 0 0 12px;
            color: var(--neon-cyan);
        }
        
        .input-group .form-control {
            border-radius: 0 12px 12px 0;
        }
        
        .btn-login {
            background: linear-gradient(135deg, var(--neon-cyan) 0%, var(--neon-purple) 100%);
            border: none;
            border-radius: 12px;
            padding: 1rem 2rem;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: #000;
            letter-spacing: 3px;
            text-transform: uppercase;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .btn-login::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.5s ease;
        }
        
        .btn-login:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 40px rgba(0, 245, 255, 0.5);
        }
        
        .btn-login:hover::before {
            left: 100%;
        }
        
        .btn-register {
            background: transparent;
            border: 2px solid var(--neon-green);
            border-radius: 12px;
            padding: 1rem 2rem;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--neon-green);
            letter-spacing: 3px;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }
        
        .btn-register:hover {
            background: var(--neon-green);
            color: #000;
            box-shadow: 0 10px 40px rgba(0, 255, 136, 0.5);
            transform: translateY(-3px);
        }
        
        .form-check-input {
            background-color: rgba(0, 245, 255, 0.1);
            border-color: var(--neon-cyan);
        }
        
        .form-check-input:checked {
            background-color: var(--neon-cyan);
            border-color: var(--neon-cyan);
        }
        
        .form-check-label {
            color: #a0a0c0;
        }
        
        .alert-success {
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid var(--neon-green);
            border-radius: 12px;
            color: var(--neon-green);
        }
        
        .text-danger {
            color: #ff0055 !important;
        }
        
        .footer-text {
            text-align: center;
            margin-top: 2rem;
            color: #606080;
            font-size: 0.85rem;
        }
        
        .footer-text i {
            color: var(--neon-cyan);
        }
        
        /* Decorative corners */
        .corner {
            position: absolute;
            width: 30px;
            height: 30px;
            border-color: var(--neon-cyan);
            border-style: solid;
        }
        
        .corner-tl { top: 10px; left: 10px; border-width: 2px 0 0 2px; }
        .corner-tr { top: 10px; right: 10px; border-width: 2px 2px 0 0; }
        .corner-bl { bottom: 10px; left: 10px; border-width: 0 0 2px 2px; }
        .corner-br { bottom: 10px; right: 10px; border-width: 0 2px 2px 0; }
    </style>
</head>
<body>
    <div class="bg-grid"></div>
    
    <div class="particles">
        @for (int i = 0; i < 20; i++)
        {
            <div class="particle" style="left: @(new Random().Next(0, 100))%; animation-delay: @(new Random().Next(0, 15))s; animation-duration: @(10 + new Random().Next(5, 10))s;"></div>
        }
    </div>
    
    <div class="login-container">
        <div class="login-card">
            <div class="corner corner-tl"></div>
            <div class="corner corner-tr"></div>
            <div class="corner corner-bl"></div>
            <div class="corner corner-br"></div>
            
            <div class="logo">
                <h1>SKILLSWAP</h1>
                <p><i class="bi bi-lightning-charge"></i> NEURAL ACCESS PORTAL</p>
            </div>
            
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success mb-4" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                }
                
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label asp-for="Email" class="form-label">
                        <i class="bi bi-envelope me-2"></i>Email
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-at"></i></span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter your email address">
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="Password" class="form-label">
                        <i class="bi bi-key me-2"></i>Password
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password">
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe">
                    <label asp-for="RememberMe" class="form-check-label" for="rememberMe">Remember me</label>
                </div>
                
                <div class="d-grid gap-3 mb-4">
                    <button type="submit" class="btn btn-login">
                        <i class="bi bi-arrow-right-circle me-2"></i>LOGIN
                    </button>
                    
                    <a asp-action="Register" class="btn btn-register">
                        <i class="bi bi-person-plus me-2"></i>SIGN UP
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
